option_settings:
  # Configuración del entorno de la aplicación
  aws:elasticbeanstalk:application:environment:
    FLASK_ENV: production
    PORT: 5000

  # Configuración del servidor Proxy (Nginx) para redirigir el tráfico al contenedor
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx

  # Configuración del balanceador de carga (Application Load Balancer)
  aws:elasticbeanstalk:environment:
    LoadBalancerType: application

  # Configuración del grupo de Auto Scaling (Mínimo 2, Máximo 5 instancias EC2)
  aws:autoscaling:asg:
    MinSize: "2"
    MaxSize: "5"

  # Configuración de los procesos del balanceador de carga
  aws:elasticbeanstalk:environment:process:default:
    Port: "5000"
    Protocol: HTTP
    HealthCheckPath: /api/orders